VITE_TMDB_KEY=your_tmdb_api_key_here
VITE_API_URL=http://localhost:3001
# Optional: deploy proxy/ on Vercel, paste the resulting URL here.
# When set, the player routes stream embeds through this proxy (bypass UZ DNS block).
# When unset, embeds load directly (fine for non-UZ networks).
VITE_EMBED_PROXY_URL=
